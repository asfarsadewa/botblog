# Injected automatically by Vercel when a Postgres database is connected.
# Run `vercel env pull .env.local` to populate these locally.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_HOST=

# Generate with: openssl rand -hex 32
# Add to Vercel via: Settings → Environment Variables
ADMIN_SECRET=
